# =============================================================================
# NEXUS — .gitignore
# =============================================================================

# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================
.env
.env.local
.env.*.local
*.key
*.pem
*.p12

# =============================================================================
# NODE / ELECTRON
# =============================================================================
node_modules/
dist/
dist-electron/
release/
out/

# Electron builder artifacts
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.tar.gz

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# PyInstaller builds
build/
*.spec

# Distribution / packaging
*.egg
*.egg-info/
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# =============================================================================
# DATABASES — never commit local data files
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# USER-GENERATED CONTENT
# =============================================================================
quotes/output/
images/storage/
public/content/projects.json

# =============================================================================
# OS
# =============================================================================
.DS_Store
._*
Thumbs.db
Desktop.ini

# =============================================================================
# EDITORS
# =============================================================================
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# TESTING
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# MISC
# =============================================================================
.cache/
.eslintcache
