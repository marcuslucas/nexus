# Nexus — Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.
# Every variable used anywhere in the platform must be documented here.

# =============================================================================
# CORE — Required for all products
# =============================================================================

# Which product to run. Must match a directory name in /products/
# Values: architect-portfolio | sol-business
NEXUS_PRODUCT=architect-portfolio

# Port Flask API server listens on
# Default: 5199 (matches original Sol-Quoter port)
FLASK_PORT=5199

# Flask environment
# Values: development | production
FLASK_ENV=development

# Absolute path to the core database (currently reserved, near-empty)
CORE_DB_PATH=/absolute/path/to/nexus-core.db

# =============================================================================
# MODULE: web-manager
# Required when NEXUS_PRODUCT includes web-manager module
# =============================================================================

# Absolute path to web-manager SQLite database file
WEB_MANAGER_DB_PATH=/absolute/path/to/web-manager.db

# Absolute path to the portfolio site's /public/content/ directory
# This is where POST /api/web-manager/export writes projects.json
SITE_CONTENT_PATH=/absolute/path/to/site/public/content

# Absolute path to directory where project images are stored
IMAGES_STORAGE_PATH=/absolute/path/to/images

# [OPTIONAL] Vercel Analytics API token
# Required to enable the Traffic screen in web-manager
# Stored via Electron safeStorage (OS-level encryption) after first entry
# Do not set this in .env for production — set it through the app UI
VERCEL_API_TOKEN=

# =============================================================================
# MODULE: sol-quoter
# Required when NEXUS_PRODUCT includes sol-quoter module
# =============================================================================

# Absolute path to sol-quoter SQLite database file
SOL_QUOTER_DB_PATH=/absolute/path/to/sol-quoter.db

# Absolute path to directory where generated .docx quote files are saved
QUOTES_OUTPUT_PATH=/absolute/path/to/quotes/output

# Confidence threshold for flagging fields in the review screen
# Fields with confidence below this value are flagged for manual review
# Default: 0.7 (range: 0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.7

# [OPTIONAL] SAM.gov API key
# Required to enable solicitation lookup by ID
# Stored via Electron safeStorage after first entry
SAM_GOV_API_KEY=

# [OPTIONAL] Anthropic API key
# Required to enable AI-assisted extraction fallback
# Stored via Electron safeStorage after first entry
# Note: Only extracted TEXT is sent — raw PDFs are never transmitted
ANTHROPIC_API_KEY=

# =============================================================================
# MODULE: product-db
# Required when NEXUS_PRODUCT includes product-db module
# =============================================================================

# Absolute path to product-db SQLite database file
PRODUCT_DB_PATH=/absolute/path/to/product-db.db

# =============================================================================
# FUTURE MODULES
# Add new module env vars here when modules are created
# =============================================================================

# MODULE: box-manifest (planned)
# BOX_MANIFEST_DB_PATH=
# BOX_MANIFEST_OUTPUT_PATH=
